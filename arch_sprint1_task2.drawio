        <mxCell id="qWzBo4xjHBIIXocbefsZ-4" value="Запросить список услуг&lt;div&gt;&lt;font color=&quot;#b3b3b3&quot;&gt;[Фильтр]&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#b3b3b3&quot;&gt;ответ: {Пользователь.ID, Услуга&lt;font size=&quot;1&quot;&gt;.ID&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#b3b3b3&quot;&gt;&lt;font size=&quot;1&quot;&gt;, детали услуги)&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" vertex="1" connectable="0" parent="qWzBo4xjHBIIXocbefsZ-3">
