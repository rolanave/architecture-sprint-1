        <mxCell id="hOD7X9IpFv7sDauf9kdg-31" value="Нотификация&lt;div&gt;&amp;nbsp;об изменении&amp;nbsp;&lt;/div&gt;&lt;div&gt;услуги&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;font color=&quot;#b3b3b3&quot;&gt;[Пользователь.ID]&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#b3b3b3&quot;&gt;[Услуга.ID]&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" vertex="1" connectable="0" parent="hOD7X9IpFv7sDauf9kdg-30">
