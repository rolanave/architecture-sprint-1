        </mxCell>
        <mxCell id="-9c2sWPQpYsPGyGz0MLr-3" value="Нотификация&lt;div&gt;&amp;nbsp;об изменении&amp;nbsp;&lt;/div&gt;&lt;div&gt;статуса&lt;/div&gt;&lt;div&gt;ставки&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#b3b3b3&quot;&gt;[Аукцион.ID]&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#b3b3b3&quot;&gt;[Заказ.ID]&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#b3b3b3&quot;&gt;[Пользователь.ID]&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#b3b3b3&quot;&gt;[Ставка.Сумма]&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#b3b3b3&quot;&gt;[Ставка.Cостояние]&lt;/font&gt;&lt;/div&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" vertex="1" connectable="0" parent="-9c2sWPQpYsPGyGz0MLr-2">
