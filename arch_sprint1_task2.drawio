        <mxCell id="qWzBo4xjHBIIXocbefsZ-6" value="&lt;div&gt;Подтвердить заказ&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(179, 179, 179);&quot;&gt;[Заказ.ID]&lt;/span&gt;&lt;br&gt;&lt;/div&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" vertex="1" connectable="0" parent="qWzBo4xjHBIIXocbefsZ-5">
